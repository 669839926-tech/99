{
  "entities": {
    "AppData": {
      "title": "Application Data",
      "description": "The main data structure for the team management system, including teams, players, and plans.",
      "type": "object",
      "properties": {
        "teams": {
          "type": "array",
          "description": "List of teams in the club"
        },
        "players": {
          "type": "array",
          "description": "List of players across all teams"
        },
        "trainingPlans": {
          "type": "array",
          "description": "List of training plans"
        },
        "playerGrowth": {
          "type": "array",
          "description": "Historical growth data for players"
        },
        "settings": {
          "type": "object",
          "description": "Application settings"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last save"
        }
      },
      "required": ["teams", "players", "trainingPlans", "playerGrowth", "settings"]
    }
  },
  "firestore": {
    "/appData/{userId}": {
      "schema": "AppData",
      "description": "Stores the application data for a specific user"
    }
  }
}
